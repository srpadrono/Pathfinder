{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/srpadrono/Pathfinder/evals/schema/triggering.schema.json",
  "title": "Pathfinder triggering eval suite",
  "description": "Should-trigger / should-not-trigger queries that measure whether the skill's description fires correctly. Negatives should be realistic near-misses.",
  "type": "object",
  "required": ["skill", "queries"],
  "properties": {
    "$schema": { "type": "string" },
    "skill": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "queries": {
      "type": "array",
      "minItems": 16,
      "description": "At least 16 queries (~8 positive, ~8 negative near-misses) per skill-creator guidance.",
      "items": {
        "type": "object",
        "required": ["id", "query", "should_trigger"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "query": { "type": "string", "minLength": 10 },
          "should_trigger": { "type": "boolean" },
          "rationale": { "type": "string" }
        }
      }
    }
  }
}
