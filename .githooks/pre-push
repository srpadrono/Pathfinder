#!/usr/bin/env bash
# Pathfinder: Block direct pushes to main/master.
# Decide from the refs actually being pushed (git passes them on stdin as
# "<local ref> <local oid> <remote ref> <remote oid>"), not the checked-out branch —
# so pushing main while on a feature branch is still blocked, and pushing a feature
# branch while standing on main is allowed.
set -euo pipefail

blocked=0
while read -r local_ref local_oid remote_ref remote_oid; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      echo "✘ Pathfinder: Direct push to ${remote_ref#refs/heads/} is blocked."
      blocked=1
      ;;
  esac
done

if [ "$blocked" -eq 1 ]; then
  echo "  Create a feature branch and open a PR instead."
  exit 1
fi

exit 0
