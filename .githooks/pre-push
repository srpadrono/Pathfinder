#!/usr/bin/env bash
# Pathfinder v0.3.0+ pre-push hook
# Blocks direct push to main/master. Forces feature branches.

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo "✘ Pathfinder: Direct push to $BRANCH is blocked."
  echo "  Create a feature branch: git checkout -b feat/<expedition-name>"
  echo "  Then push: git push origin feat/<expedition-name>"
  exit 1
fi

exit 0
