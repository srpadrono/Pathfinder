#!/usr/bin/env bash
# Pathfinder: Ensure staged journeys.json files stay valid
set -euo pipefail

FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '(^|/)(\.pathfinder|pathfinder)/journeys\.json$' || true)
[ -n "$FILES" ] || exit 0

status=0
for file in $FILES; do
  python3 -c "import json, sys; json.load(open(sys.argv[1]))" "$file" 2>/dev/null || {
    echo "✘ Pathfinder: $file is invalid JSON."
    status=1
  }
done

exit $status
