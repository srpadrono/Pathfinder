{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/srpadrono/Pathfinder/main/skills/pathfinder/schema/journeys.schema.json",
  "title": "Pathfinder journey map",
  "description": "The journey map — Pathfinder's source of truth. Lives at <testDir>/pathfinder/journeys.json.",
  "type": "object",
  "required": ["journeys"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "project": { "type": "string" },
    "framework": { "type": "string" },
    "journeys": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "steps"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "description": "Journey id, e.g. AUTH or ITEMS-CREATE." },
          "name": { "type": "string" },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "action", "screen", "tested"],
              "additionalProperties": true,
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[A-Z]+-[0-9]{2}$",
                  "description": "Step id in PREFIX-NN form (e.g. AUTH-01). Reuse the same id across journeys at a shared branching point to render a decision diamond."
                },
                "action": { "type": "string", "description": "User-facing action, phrased \"User does X\"." },
                "screen": { "type": "string", "description": "View/component/screen name." },
                "tested": {
                  "oneOf": [
                    { "type": "boolean" },
                    { "type": "string", "enum": ["partial"] }
                  ],
                  "description": "true (passing UI test), false (no coverage), or \"partial\" (written but disabled / implicitly covered)."
                },
                "testFile": { "type": "string", "description": "Path to the test covering this step." },
                "note": { "type": "string", "description": "Required when tested is \"partial\": why it's partial." }
              }
            }
          }
        }
      }
    }
  }
}
