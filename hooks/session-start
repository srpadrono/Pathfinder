#!/usr/bin/env bash
# SessionStart hook for Pathfinder

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

using_content=$(cat "${PLUGIN_ROOT}/skills/pathfinder/SKILL.md" 2>&1 || echo "Error reading skill")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

escaped=$(escape_for_json "$using_content")
ctx="You have Pathfinder — a UI test coverage mapping tool.\\n\\n${escaped}"

cat <<EOF
{
  "additional_context": "${ctx}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${ctx}"
  }
}
EOF
exit 0
