#!/usr/bin/env bash
# SessionStart hook for Pathfinder
# Injects a lean summary — the plugin skill system loads full content on invocation.

set -euo pipefail

ctx="You have Pathfinder — a UI test coverage mapping tool.\\nWorkflow: /map (discover journeys) → /blaze (visualize coverage) → /scout (write tests) → /summit (verify & report).\\nSupports Playwright, Cypress, Maestro, Detox, XCUITest, Espresso, Flutter."

cat <<EOF
{
  "additional_context": "${ctx}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${ctx}"
  }
}
EOF
exit 0
